{
  "name": "StoiCom - Correos diarios",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 * * *"
            }
          ]
        }
      },
      "id": "a1000000-0000-0000-0000-000000000001",
      "name": "Trigger 6:00 am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://stoic-mu.vercel.app/api/cron/daily-email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer TU_CRON_SECRET"
            }
          ]
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "a1000000-0000-0000-0000-000000000002",
      "name": "Correo matutino",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "30 20 * * *"
            }
          ]
        }
      },
      "id": "a1000000-0000-0000-0000-000000000003",
      "name": "Trigger 8:30 pm",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://stoic-mu.vercel.app/api/cron/evening-email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer TU_CRON_SECRET"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      },
      "id": "a1000000-0000-0000-0000-000000000004",
      "name": "Correo nocturno",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 200]
    }
  ],
  "connections": {
    "Trigger 6:00 am": {
      "main": [
        [
          {
            "node": "Correo matutino",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger 8:30 pm": {
      "main": [
        [
          {
            "node": "Correo nocturno",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "America/Bogota",
    "executionOrder": "v1"
  }
}
