{
  "name": "StoiCom - Correos diarios (horario por usuario)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 * * * *"
            }
          ]
        }
      },
      "id": "a1000000-0000-0000-0000-000000000001",
      "name": "Cada hora",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://stoicom.app/api/cron/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer TU_CRON_SECRET"
            }
          ]
        },
        "options": {
          "timeout": 300000
        }
      },
      "id": "a1000000-0000-0000-0000-000000000002",
      "name": "Correos (matutino + nocturno)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    }
  ],
  "connections": {
    "Cada hora": {
      "main": [
        [
          {
            "node": "Correos (matutino + nocturno)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "timezone": "America/Bogota",
    "executionOrder": "v1"
  }
}
